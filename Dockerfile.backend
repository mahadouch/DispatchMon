FROM php:8.3-cli

# Install system deps
RUN apt-get update && apt-get install -y \
    git curl zip unzip libpng-dev libjpeg-dev libfreetype6-dev \
    libonig-dev libxml2-dev libsqlite3-dev \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install pdo pdo_sqlite mbstring exif pcntl bcmath gd \
    && rm -rf /var/lib/apt/lists/*

# Install Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

WORKDIR /var/www/html

# Create fresh Laravel project
RUN composer create-project laravel/laravel . --prefer-dist --no-interaction \
    && rm -rf .git

# Copy our custom files
COPY backend/app /var/www/html/app
COPY backend/database /var/www/html/database
COPY backend/routes /var/www/html/routes
COPY backend/config /var/www/html/config
COPY backend/bootstrap/app.php /var/www/html/bootstrap/app.php
COPY VERSION /var/www/html/VERSION

# Storage permissions
RUN chmod -R 777 storage bootstrap/cache

# Copy entrypoint
COPY backend/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Set environment
ENV APP_ENV=local
ENV APP_DEBUG=true
ENV DB_CONNECTION=sqlite
ENV DB_DATABASE=/var/www/html/database/database.sqlite

EXPOSE 8000

ENTRYPOINT ["entrypoint.sh"]
